{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "vite",
  "routes": [
    {
      "src": "/robots.txt",
      "dest": "/api/robots"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/api/sitemap"
    },
    {
      "src": "/supabase/(.*)",
      "dest": "https://elrnafeyidalkswgdqvx.supabase.co/$1"
    },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
